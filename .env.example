# Models to preload at startup (comma-separated)
OLLAMA_MODELS=qwen3.5:4b,qwen3.5:2b,qwen3.5:0.8b 

# Default model used by local Python app
OLLAMA_MODEL=qwen3.5:4b

# Ollama endpoint port used by local Python app
OLLAMA_PORT=11434

# Keep model loaded in memory to reduce cold-start latency
OLLAMA_KEEP_ALIVE=24h